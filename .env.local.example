# `.env.local` 템플릿 — 이 파일을 복사해 프로젝트 루트에 `.env.local` 로 저장한 뒤 값을 채우세요.
# 실제 비밀값은 커밋하지 마세요. (`gitignore`에 `.env.local` 포함)
#
# 병합 규칙: 먼저 `.env`를 읽고, `.env.local`에서 값이 비어 있지 않은 항목만 덮어씁니다.
# 자세한 설명: docs/env-setup.md

VISITKOREA_SERVICE_KEY=
VISITKOREA_MOBILE_APP=MovieSSam
TOURAPI_SERVER_PORT=3080
VITE_APP_NAME=MovieSSam
VITE_KAKAO_MAP_JS_KEY=

# 선택: 혼잡 업스트림 (서버 전용 · 루트 env에만 — 브라우저 번들에 넣지 말 것)
# CROWD_API_BASE_URL=
# CROWD_API_KEY=
# CROWD_API_TIMEOUT_MS=10000
