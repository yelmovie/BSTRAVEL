# 이 파일은 `.env.local.example` 과 동일 목적입니다. 신규 프로젝트는 `.env.local.example` 사용을 권장합니다.
# 복구: `pnpm env:restore` (루트에 `.env.local` 없을 때만 템플릿 복사)
# 상세: docs/env-setup.md
#
# 이 파일을 복사해 프로젝트 루트에 `.env.local` 로 저장한 뒤 값을 채우세요.
# `.env.local` 은 git에 올리지 마세요.
#
# 참고: 비워 둔 `키=` 줄은 `.env`에 넣어 둔 같은 이름의 값을 덮어쓰지 않습니다.
#       (비어 있는 예시만 복사했다면 실제 키는 `.env`에 두면 됩니다.)

VISITKOREA_SERVICE_KEY=
VISITKOREA_MOBILE_APP=MovieSSam
TOURAPI_SERVER_PORT=3080
VITE_APP_NAME=MovieSSam
VITE_KAKAO_MAP_JS_KEY=
# 선택: 혼잡 업스트림 (서버 전용 — 루트 .env 또는 .env.local 에만 설정, VITE_ 접두사 금지)
# CROWD_API_BASE_URL=
# CROWD_API_KEY=
# CROWD_API_TIMEOUT_MS=10000
