# 환경 변수 가이드: docs/env-setup.md · 복구 `pnpm env:restore` · 점검 `pnpm env:check`
#
# 로딩 순서: `.env`를 읽은 뒤 `.env.local`에서 값이 채워진 항목만 덮어씁니다.
# (예시만 복사한 `.env.local`의 빈 `키=` 때문에 `.env`의 키가 무시되지 않도록 server·Vite 동일 규칙 적용)

# ── TourAPI (서버 전용 — Vite 클라이언트에 주입하지 마세요) ─────────────
# 공공데이터포털에서 발급한 디코딩(일반 텍스트) 인증키를 넣는 것을 권장합니다.
# 이미 URL 인코딩된 키를 넣었다면 이중 인코딩으로 실패할 수 있습니다.
VISITKOREA_SERVICE_KEY=

# TourAPI 필수 파라미터 MobileApp (공식 문서: 서비스(앱) 이름)
VISITKOREA_MOBILE_APP=MovieSSam

# 로컬 프록시 서버 포트 — vite.config.ts 의 `/api/tour`, `/api/crowd` proxy 가 이 포트로 전달
# (날씨 `/api/weather` 는 이 프록시에 포함되지 않음 → 아래 VITE_API_BASE_URL 또는 vercel dev 참고)
TOURAPI_SERVER_PORT=3080

# Vite 단독 실행 시 브라우저가 상대경로 `/api/weather` 만 쓰면 백엔드 없어 404 가능 — 버그 아님.
# 해결: `pnpm dev`(api+vite), 또는 본 설정으로 tourApi(3080) 직접 지정, 또는 `vercel dev`
# 예: VITE_API_BASE_URL=http://127.0.0.1:3080  (server/tourApi.mjs 가 weatherShared 동일 로직)
# 프로덕션(Vercel 동일 출처): 비움 → `api/weather.mjs`

# (선택) 브라우저가 3080 등 다른 출처로 직접 호출할 때 CORS — server/tourApi.mjs (기본 dev 허용)
# TOURAPI_CORS=1

# (선택) VISITKOREA_SERVICE_KEY 없으면 서버 기동 시 즉시 종료 — 로컬 개발은 비워두고 경고만 보려면 생략
# TOURAPI_THROW_IF_NO_KEY=1

# (선택) 프록시(/api/tour/*) 요청 로깅 강화 — server/tourApi.mjs · visitkoreaClient.mjs
# TOURAPI_PROXY_DEBUG=1

# ── 클라이언트 (Vite: VITE_ 접두사) ────────────────────────────────────
# 카카오맵 JavaScript 키 — 카카오 디벨로퍼스 웹 플랫폼에 도메인 등록 후 사용
VITE_KAKAO_MAP_JS_KEY=

# 앱 표시명(선택)
VITE_APP_NAME=MovieSSam

# 시연 확장 UI(예시 코스·비교·정렬 칩 등). 기본 비활성 — 공모전 핵심 경로만 노출하려면 false 또는 생략
VITE_DEMO_MODE=false

# ── 날씨 (클라이언트 → 내부 `/api/weather` 만 호출; Open-Meteo는 서버 전용) ───
# 동일 출처 배포 시 비움. 로컬에서만 필요 시:
# VITE_API_BASE_URL=http://127.0.0.1:3080

# ── 혼잡 외부 API (서버 전용 — 브라우저에 넣지 마세요 · VITE_ 접두사 금지) ─────
# 클라이언트는 GET /api/crowd 만 호출하고, server/tourApi.mjs + crowdApi.mjs 가 여기 설정으로 업스트림 호출합니다.
# 비어 있으면 /api/crowd 는 503 NOT_CONFIGURED (연동 안 함 상태)
# CROWD_API_ENABLED=false 로 프록시 비활성화 가능
# CROWD_API_BASE_URL=
# CROWD_API_KEY=
# CROWD_API_TIMEOUT_MS=10000

# ── 사용 위치 요약 (검증용) ───────────────────────────────────────────
# VISITKOREA_SERVICE_KEY  → server/visitkoreaClient.mjs (tourApi.mjs 경유: /api/tour/*)
# VITE_KAKAO_MAP_JS_KEY  → src/app/lib/kakao/loadKakaoMapsSdk.ts
# Open-Meteo 격자 예보    → 브라우저 직접 호출 없음 — server/weatherShared.mjs · Vercel api/weather.mjs
# CROWD_*                 → server/crowdApi.mjs (경유: /api/crowd) · 클라 src/app/lib/crowd/crowdClient.ts
